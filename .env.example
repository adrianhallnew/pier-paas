# Copy to .env.local and fill every value.

# OCI
OCI_TENANCY_OCID=CHANGEME_ocid1.tenancy.oc1..
OCI_USER_OCID=CHANGEME_ocid1.user.oc1..
OCI_FINGERPRINT=CHANGEME_xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=~/.oci/pier_oci.pem
OCI_REGION=CHANGEME_ap-mumbai-1
OCI_COMPARTMENT_OCID=CHANGEME_ocid1.tenancy.oc1..   # root compartment = same as tenancy OCID

# DuckDNS
DUCKDNS_TOKEN=CHANGEME_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DUCKDNS_ROOT=CHANGEME_pier-yourname.duckdns.org

# GitHub
GITHUB_PAT=CHANGEME_github_pat_

# Network
OPERATOR_CIDR=CHANGEME_1.2.3.4/32   # run: curl ifconfig.me
